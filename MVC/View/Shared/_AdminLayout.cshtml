@{
    var controller = (ViewContext.RouteData.Values["controller"] ?? "").ToString();
    string ActiveClass(params string[] names) =>
        names.Any(n => string.Equals(n, controller, StringComparison.OrdinalIgnoreCase))
            ? "active" : string.Empty;
    var nombre = User?.Identity?.Name ?? "Usuario";
    var rol = User?.Claims?.FirstOrDefault(c => c.Type.EndsWith("/role"))?.Value ?? "";
    var inicial = !string.IsNullOrWhiteSpace(nombre) ? nombre.Substring(0, 1).ToUpper() : "U";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Transportes Tobón</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-shell">

        <aside class="admin-sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-truck"></i></div>
                <span class="brand-text">Tobón.</span>
            </div>

            <div class="user-card">
                <div class="user-avatar">@inicial</div>
                <div class="user-meta">
                    <small class="user-role">@(string.IsNullOrEmpty(rol) ? "Usuario" : rol)</small>
                    <strong class="user-name">@nombre</strong>
                </div>
                <i class="bi bi-chevron-down ms-auto text-muted"></i>
            </div>

            <div class="menu-section">
                <span class="menu-label">MENÚ PRINCIPAL</span>
                <a class="menu-item @ActiveClass("Dashboard","Home")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-pie-chart"></i><span>Dashboard</span>
                </a>
                <a class="menu-item @ActiveClass("Clientes")" asp-controller="Clientes" asp-action="Index">
                    <i class="bi bi-briefcase"></i><span>Gestión de Clientes</span>
                    <i class="bi bi-chevron-right ms-auto"></i>
                </a>
                <a class="menu-item @ActiveClass("Vehiculos","Conductores")" asp-controller="Vehiculos" asp-action="Index">
                    <i class="bi bi-truck"></i><span>Flota y Conductores</span>
                </a>
                <a class="menu-item" href="#">
                    <i class="bi bi-signpost-split"></i><span>Rutas</span>
                </a>
                <a class="menu-item" href="#">
                    <i class="bi bi-graph-up"></i><span>Reportes</span>
                </a>
                @if (User?.IsInRole("Administrador") == true)
                {
                    <a class="menu-item @ActiveClass("Usuarios")" asp-controller="Usuarios" asp-action="Index">
                        <i class="bi bi-people"></i><span>Usuarios</span>
                    </a>
                }
            </div>

            <div class="support-card">
                <span class="menu-label">SOPORTE</span>
                <p class="support-text">¿Necesitas ayuda con el sistema?</p>
                <a class="btn btn-outline-secondary btn-sm w-100" href="#">Contactar Soporte</a>
            </div>

            <div class="user-footer">
                <div class="user-avatar small">@inicial</div>
                <div class="user-meta">
                    <small class="user-role">@(string.IsNullOrEmpty(rol) ? "Usuario" : rol)</small>
                    <strong class="user-name">@nombre</strong>
                </div>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="ms-auto">
                    <button type="submit" class="btn btn-link p-0 text-muted" title="Cerrar sesión">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </aside>

        <main class="admin-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
