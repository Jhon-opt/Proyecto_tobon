@{
    var heading = ViewData["AuthHeading"] as string ?? "Gestión Logística Inteligente";
    var subtitle = ViewData["AuthSubtitle"] as string
        ?? "Acceda a su panel de control para monitorear envíos, gestionar flotas y optimizar sus rutas en tiempo real.";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Transportes Tobón</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">

    <div class="auth-shell">
        <aside class="auth-side">
            <div class="brand-row">
                <div class="brand-icon"><i class="bi bi-truck"></i></div>
                <span class="brand-text">Transportes Tobón</span>
            </div>

            <div class="side-content">
                <h1 class="side-heading">@heading</h1>
                <p class="side-subtitle">@subtitle</p>
            </div>

            <div class="side-footer">
                <small>© 2026 Transportes Tobón S.A.S.</small>
            </div>
        </aside>

        <section class="auth-form-area">
            <div class="auth-form-wrapper">
                @RenderBody()
            </div>
        </section>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
