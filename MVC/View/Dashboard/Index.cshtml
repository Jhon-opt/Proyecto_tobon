@{
    ViewData["Title"] = "Panel de Control";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1>Panel de Control</h1>
    <p>Bienvenido, @User.Identity?.Name. Selecciona un módulo para comenzar.</p>
</div>

<div class="row g-3">
    @if (User.IsInRole("Administrador"))
    {
        <div class="col-md-4">
            <div class="list-card h-100">
                <div class="display-6 text-primary mb-2"><i class="bi bi-people"></i></div>
                <h5 class="mb-1">Gestión de Usuarios</h5>
                <p class="text-muted small">Consulta, edita y desactiva el personal de la plataforma.</p>
                <a asp-controller="Usuarios" asp-action="Index" class="btn-primary-dark">Administrar</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="list-card h-100">
                <div class="display-6 text-success mb-2"><i class="bi bi-person-vcard"></i></div>
                <h5 class="mb-1">Gestión de Clientes</h5>
                <p class="text-muted small">Registra, consulta y edita los clientes de la empresa.</p>
                <a asp-controller="Clientes" asp-action="Index" class="btn-primary-dark">Administrar</a>
            </div>
        </div>
    }

    <div class="col-md-4">
        <div class="list-card h-100">
            <div class="display-6 text-warning mb-2"><i class="bi bi-truck"></i></div>
            <h5 class="mb-1">Flota de Vehículos</h5>
            <p class="text-muted small">Control de estado y disponibilidad de camiones.</p>
            <a asp-controller="Vehiculos" asp-action="Index" class="btn-primary-dark">Ver Flota</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="list-card h-100">
            <div class="display-6 text-info mb-2"><i class="bi bi-person-badge"></i></div>
            <h5 class="mb-1">Conductores</h5>
            <p class="text-muted small">Vigencia de licencias y disponibilidad operativa.</p>
            <a asp-controller="Conductores" asp-action="Index" class="btn-primary-dark">Ver Conductores</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="list-card h-100">
            <div class="display-6 text-secondary mb-2"><i class="bi bi-box-seam"></i></div>
            <h5 class="mb-1">Pedidos y Cargas</h5>
            <p class="text-muted small">Visualiza las solicitudes de transporte de los clientes.</p>
            <a href="#" class="btn-primary-dark">Ver Pedidos</a>
        </div>
    </div>
</div>
