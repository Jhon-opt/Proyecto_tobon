@model TransportesTobonApp.MVC.Models.Usuario
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_AuthLayout";
}

<h1 class="form-title">Iniciar Sesión</h1>
<p class="form-lead">Ingrese sus credenciales para acceder al sistema.</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-soft alert-success">
        <div class="alert-icon"><i class="bi bi-check"></i></div>
        <div class="alert-body">
            <strong>Listo</strong>
            <small>@TempData["SuccessMessage"]</small>
        </div>
    </div>
}

@if (ViewBag.Message != null)
{
    <div class="alert-soft">
        <div class="alert-icon"><i class="bi bi-exclamation"></i></div>
        <div class="alert-body">
            <strong>Credenciales inválidas</strong>
            <small>@ViewBag.Message</small>
        </div>
    </div>
}

<form asp-controller="Auth" asp-action="Login" method="post">
    <div class="field">
        <label class="field-label" for="email">Correo Electrónico</label>
        <div class="field-input @(ViewBag.Message != null ? "is-invalid" : "")">
            <i class="bi bi-envelope leading-icon"></i>
            <input id="email" type="email" name="email" placeholder="admin@transportestobon.com" required autofocus />
        </div>
    </div>

    <div class="field">
        <label class="field-label" for="password">
            <span>Contraseña</span>
            <a class="helper-link" href="#">¿Olvidó su contraseña?</a>
        </label>
        <div class="field-input @(ViewBag.Message != null ? "is-invalid" : "")">
            <i class="bi bi-lock leading-icon"></i>
            <input id="password" type="password" name="password" placeholder="••••••••••••" required />
            <button type="button" class="trailing-btn" onclick="togglePwd()" aria-label="Mostrar contraseña">
                <i class="bi bi-eye-slash" id="pwdIcon"></i>
            </button>
        </div>
    </div>

    <div class="row-line">
        <input type="checkbox" id="recordar" name="RememberMe" checked />
        <label for="recordar">Recordar sesión</label>
    </div>

    <button type="submit" class="btn-auth">
        Ingresar al Sistema <i class="bi bi-arrow-right"></i>
    </button>
</form>

<div class="auth-foot">
    ¿Necesita acceso? <a asp-action="Registro">Contacte al administrador</a>
    <div class="auth-icons">
        <i class="bi bi-question-circle"></i>
        <i class="bi bi-shield-lock"></i>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd() {
        var input = document.getElementById('password');
        var icon = document.getElementById('pwdIcon');
        if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye'; }
        else { input.type = 'password'; icon.className = 'bi bi-eye-slash'; }
    }
</script>
}
