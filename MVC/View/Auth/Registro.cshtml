@model TransportesTobonApp.MVC.Models.Usuario
@{
    ViewData["Title"] = "Registro - Transportes Tobón";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-success text-white text-center py-3">
                <h4 class="mb-0">Crear Cuenta</h4>
                <small>Transportes Tobón - Gestión Logística</small>
            </div>
            <div class="card-body p-4">
                <form asp-controller="Auth" asp-action="Registro" method="post">
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Nombre Completo</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" asp-for="Nombre" class="form-control" placeholder="Ej: Juan Pérez" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input type="email" asp-for="Email" class="form-control" placeholder="usuario@transportestobon.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Contraseña</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="password" asp-for="Password" class="form-control" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label font-weight-bold">Tipo de Empleado (Rol)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                            <select asp-for="Rol" class="form-select" required>
                                <option value="" selected disabled>Seleccione un cargo...</option>
                                <option value="Administrador">Administrador</option>
                                <option value="Operador">Operador</option>
                                <option value="Conductor">Conductor</option>
                            </select>
                        </div>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-warning py-2 text-center shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Message
                        </div>
                    }

                    <button type="submit" class="btn btn-success w-100 py-2 shadow-sm mb-3">
                        <strong>Finalizar Registro</strong>
                    </button>

                    <hr />

                    <div class="text-center">
                        <span class="text-muted small">¿Ya tienes una cuenta corporativa?</span><br />
                        <a asp-controller="Auth" asp-action="Login" class="text-decoration-none fw-bold">Iniciar Sesión</a>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <span class="text-muted extra-small">&copy; 2026 Transportes Tobón S.A.S.</span>
            </div>
        </div>
    </div>
</div>