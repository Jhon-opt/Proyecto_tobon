@model TransportesTobonApp.MVC.Models.Usuario
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = "_AuthLayout";
    ViewData["AuthHeading"] = "Únase al equipo Tobón";
    ViewData["AuthSubtitle"] = "Cree su cuenta corporativa para administrar pedidos, flota y clientes desde un solo panel.";
}

<h1 class="form-title">Crear Cuenta</h1>
<p class="form-lead">Diligencie sus datos para registrar un nuevo usuario en el sistema.</p>

@if (ViewBag.Message != null)
{
    <div class="alert-soft">
        <div class="alert-icon"><i class="bi bi-exclamation"></i></div>
        <div class="alert-body">
            <strong>No fue posible registrar</strong>
            <small>@ViewBag.Message</small>
        </div>
    </div>
}

<form asp-controller="Auth" asp-action="Registro" method="post">
    <div class="field">
        <label class="field-label" for="Nombre">Nombre Completo</label>
        <div class="field-input">
            <i class="bi bi-person leading-icon"></i>
            <input id="Nombre" asp-for="Nombre" placeholder="Ej: Juan Pérez" required autofocus />
        </div>
    </div>

    <div class="field">
        <label class="field-label" for="Email">Correo Electrónico</label>
        <div class="field-input">
            <i class="bi bi-envelope leading-icon"></i>
            <input id="Email" asp-for="Email" type="email" placeholder="usuario@transportestobon.com" required />
        </div>
    </div>

    <div class="field">
        <label class="field-label" for="Password">Contraseña</label>
        <div class="field-input">
            <i class="bi bi-lock leading-icon"></i>
            <input id="Password" asp-for="Password" type="password" placeholder="••••••••" required />
            <button type="button" class="trailing-btn" onclick="togglePwd()" aria-label="Mostrar contraseña">
                <i class="bi bi-eye-slash" id="pwdIcon"></i>
            </button>
        </div>
    </div>

    <div class="field">
        <label class="field-label" for="Rol">Tipo de Empleado (Rol)</label>
        <div class="field-input">
            <i class="bi bi-briefcase leading-icon"></i>
            <select id="Rol" asp-for="Rol" required>
                <option value="" selected disabled>Seleccione un cargo...</option>
                <option value="Administrador">Administrador</option>
                <option value="Operador">Operador</option>
                <option value="Conductor">Conductor</option>
            </select>
        </div>
    </div>

    <button type="submit" class="btn-auth">
        Finalizar Registro <i class="bi bi-arrow-right"></i>
    </button>
</form>

<div class="auth-foot">
    ¿Ya tiene una cuenta corporativa? <a asp-action="Login">Iniciar sesión</a>
    <div class="auth-icons">
        <i class="bi bi-question-circle"></i>
        <i class="bi bi-shield-lock"></i>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd() {
        var input = document.getElementById('Password');
        var icon = document.getElementById('pwdIcon');
        if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye'; }
        else { input.type = 'password'; icon.className = 'bi bi-eye-slash'; }
    }
</script>
}
