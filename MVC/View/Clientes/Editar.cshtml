@model TransportesTobonApp.MVC.Models.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Actualizar Cliente</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Editar" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="NitCC" />

                    <div class="row">
                        <div class="mb-3 col-md-7">
                            <label class="form-label fw-bold">Nombre o Razón Social <span class="text-danger">*</span></label>
                            <input type="text" asp-for="Nombre" class="form-control" required />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 col-md-5">
                            <label class="form-label fw-bold">NIT/CC (no editable)</label>
                            <input type="text" value="@Model.NitCC" class="form-control" readonly disabled />
                        </div>
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-6">
                            <label class="form-label fw-bold">Teléfono</label>
                            <input type="text" asp-for="Telefono" class="form-control" />
                        </div>
                        <div class="mb-3 col-md-6">
                            <label class="form-label fw-bold">Email</label>
                            <input type="email" asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Dirección</label>
                        <input type="text" asp-for="Direccion" class="form-control" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Nota interna</label>
                        <textarea asp-for="Nota" class="form-control" rows="3"></textarea>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Message</div>
                    }

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary shadow-sm">
                            <strong>Guardar Cambios</strong>
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
