@model IEnumerable<TransportesTobonApp.MVC.Models.Conductor>
@{
    ViewData["Title"] = "Gestión de Conductores";
    Layout = "_AdminLayout";
    var filtro = ViewBag.Filtro as string ?? string.Empty;
    var estado = ViewBag.Estado as string ?? string.Empty;
}

<div class="page-header">
    <h1>Gestión de Conductores</h1>
    <p>Control de personal, vigencia de licencias y disponibilidad operativa.</p>
</div>

@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="list-card">
    <div class="list-card-header">
        <h2>Gestión de Conductores</h2>
        <form asp-action="Index" method="get" class="search">
            <i class="bi bi-search"></i>
            <input type="text" name="filtro" value="@filtro" placeholder="Buscar por nombre o documento..." />
            @if (!string.IsNullOrEmpty(estado)) { <input type="hidden" name="estado" value="@estado" /> }
        </form>
        <form asp-action="Index" method="get" class="d-inline">
            @if (!string.IsNullOrEmpty(filtro)) { <input type="hidden" name="filtro" value="@filtro" /> }
            <select name="estado" class="btn-soft" onchange="this.form.submit()" style="padding-right:32px">
                <option value="">Todos los estados</option>
                <option value="Disponible"   selected="@(estado == "Disponible")">Disponible</option>
                <option value="En descanso"  selected="@(estado == "En descanso")">En descanso</option>
                <option value="Incapacitado" selected="@(estado == "Incapacitado")">Incapacitado</option>
            </select>
        </form>
        <a asp-action="Crear" class="btn-primary-dark"><i class="bi bi-plus-lg me-1"></i>Vincular Conductor</a>
    </div>

    <div class="table-responsive">
        <table class="t-modern">
            <thead>
                <tr>
                    <th>Conductor</th>
                    <th>Documento</th>
                    <th>Licencia</th>
                    <th>Teléfono</th>
                    <th>Servicios activos</th>
                    <th>Estado operativo</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No se encontraron conductores.</td></tr>
            }
            else
            {
                foreach (var c in Model)
                {
                    var inicial = string.IsNullOrWhiteSpace(c.Nombre) ? "?" : c.Nombre.Trim().Substring(0,1).ToUpper();
                    var disponible    = c.Estado == "Disponible";
                    var enDescanso    = c.Estado == "En descanso";
                    var incapacitado  = c.Estado == "Incapacitado";
                    var badgeClass    = disponible ? "badge-active" : enDescanso ? "badge-inactive" : "badge-danger";
                    var siguiente     = disponible ? "En descanso" : "Disponible";
                    var requiereConf  = (c.EnServicio && TransportesTobonApp.MVC.Models.Conductor.EstadosNoDisponibles.Contains(siguiente));
                    <tr>
                        <td class="cell-strong">
                            <span class="row-avatar">@inicial</span>@c.Nombre
                        </td>
                        <td>CC @c.Documento</td>
                        <td>@c.Licencia</td>
                        <td>@(string.IsNullOrWhiteSpace(c.Telefono) ? "—" : c.Telefono)</td>
                        <td>
                            @if (c.EnServicio)
                            {
                                <span class="badge-state badge-inactive" title="Asignado a servicio activo">
                                    <i class="bi bi-link-45deg me-1"></i>@c.ServiciosActivos
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            <form asp-action="CambiarEstado" method="post" class="d-inline js-cambio-estado"
                                  data-requiere-conf="@(requiereConf ? "1" : "0")"
                                  data-recurso="conductor @c.Nombre"
                                  data-activos="@c.ServiciosActivos"
                                  data-siguiente="@siguiente">
                                <input type="hidden" name="id" value="@c.Id" />
                                <input type="hidden" name="nuevoEstado" value="@siguiente" />
                                <input type="hidden" name="confirmado" value="false" />
                                <label class="t-toggle">
                                    <input type="checkbox" @(disponible ? "checked" : "") onchange="manejarToggle(this.form, event)" />
                                    <span class="slider"></span>
                                </label>
                            </form>
                            <div class="mt-1">
                                <span class="badge-state @badgeClass">@c.Estado</span>
                            </div>
                        </td>
                        <td>
                            <div class="t-actions justify-content-end">
                                <a class="btn-line" asp-action="Editar" asp-route-id="@c.Id"><i class="bi bi-pencil me-1"></i>Editar</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <div class="list-footer">
        <span>Mostrando 1 a @Model.Count() de @Model.Count() conductores</span>
        <div class="pager">
            <button class="page" disabled>Anterior</button>
            <button class="page active">1</button>
            <button class="page" disabled>Siguiente</button>
        </div>
    </div>
</div>

@* CdP_010: modal Bootstrap de advertencia para cambio de estado con servicios activos *@
<div class="modal fade" id="modalServiciosActivos" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning-subtle">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                    Servicios activos asignados
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="modalRecursoTexto" class="mb-2"></p>
                <p class="mb-0 text-muted">
                    El cambio podría afectar la operación en curso.
                    ¿Confirma que desea continuar?
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-soft" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-primary-dark" id="btnConfirmarCambio">
                    <i class="bi bi-check2 me-1"></i>Sí, cambiar de todos modos
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let formPendiente = null;

    function manejarToggle(form, ev) {
        if (ev) ev.preventDefault();
        const requiereConf = form.dataset.requiereConf === '1';
        if (!requiereConf) { form.submit(); return; }

        const recurso = form.dataset.recurso;
        const activos = form.dataset.activos;
        const sig     = form.dataset.siguiente;
        document.getElementById('modalRecursoTexto').innerHTML =
            'El <strong>' + recurso + '</strong> tiene <strong>' + activos +
            ' servicio(s) activo(s)</strong>. Va a cambiar su estado a <strong>' + sig + '</strong>.';
        formPendiente = form;
        new bootstrap.Modal(document.getElementById('modalServiciosActivos')).show();
    }

    document.getElementById('btnConfirmarCambio').addEventListener('click', function () {
        if (!formPendiente) return;
        formPendiente.querySelector('input[name="confirmado"]').value = 'true';
        formPendiente.submit();
    });
</script>
}
