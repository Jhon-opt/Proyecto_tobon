@model TransportesTobonApp.MVC.Models.Vehiculo
@{
    ViewData["Title"] = "Registrar Vehículo";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1>Registrar Vehículo</h1>
    <p>Añade un camión a la flota operativa de Transportes Tobón.</p>
</div>

<div class="list-card" style="max-width:720px">
    <form asp-action="Crear" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"
             style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold">Placa <span class="text-danger">*</span></label>
                <input asp-for="Placa" class="form-control" placeholder="Ej: ABC-123" required />
                <span asp-validation-for="Placa" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Modelo <span class="text-danger">*</span></label>
                <input asp-for="Modelo" class="form-control" placeholder="Ej: Volvo FH" required />
                <span asp-validation-for="Modelo" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Capacidad (toneladas)</label>
                <input asp-for="CapacidadToneladas" type="number" step="0.01" min="0" class="form-control" placeholder="Ej: 20.00" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Estado inicial</label>
                <input type="hidden" asp-for="Estado" value="Disponible" />
                <input class="form-control" value="Disponible" readonly disabled />
                <small class="text-muted">Todo vehículo nuevo se registra como Disponible.</small>
            </div>
        </div>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-danger mt-3">@ViewBag.Message</div>
        }

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary-dark"><i class="bi bi-check2 me-1"></i>Registrar Vehículo</button>
            <a asp-action="Index" class="btn-soft">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
