@model IEnumerable<TransportesTobonApp.MVC.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "_AdminLayout";
    var filtro = ViewBag.Filtro as string ?? string.Empty;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill me-2"></i>Personal Registrado</h2>
        <a asp-controller="Auth" asp-action="Registro" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Usuario
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="card card-body shadow-sm mb-3">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" name="filtro" value="@filtro" class="form-control" placeholder="Buscar por nombre o email..." />
            <button type="submit" class="btn btn-primary">Buscar</button>
            @if (!string.IsNullOrEmpty(filtro))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
            }
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Fecha de creación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No se encontraron usuarios.</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><strong>@item.Nombre</strong></td>
                            <td>@item.Email</td>
                            <td><span class="badge bg-info text-dark">@item.Rol</span></td>
                            <td>
                                <span class="badge @(item.Estado ? "bg-success" : "bg-danger")">
                                    @(item.Estado ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="ToggleEstado" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="estadoActual" value="@item.Estado.ToString().ToLower()" />
                                        <button type="submit" class="btn btn-sm @(item.Estado ? "btn-outline-warning" : "btn-outline-success")">
                                            <i class="bi @(item.Estado ? "bi-person-x" : "bi-person-check")"></i>
                                        </button>
                                    </form>

                                    <form asp-action="Eliminar" method="post" onsubmit="return confirm('¿Borrar permanentemente?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
