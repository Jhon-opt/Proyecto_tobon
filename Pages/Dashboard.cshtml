@page
@model TransportesTobonApp.Pages.DashboardModel
@{
    ViewData["Title"] = "Panel de Control - Transportes Tobón";
}

<div class="container mt-5">
    @if (TempData["UsuarioNombre"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-person-check-fill me-2"></i>
            <strong>¡Bienvenido de nuevo!</strong> Has ingresado como: @TempData["UsuarioNombre"] 
            <span class="badge bg-light text-dark ms-2">@TempData.Peek("UsuarioRol")</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-12 mb-4">
            <h2 class="border-bottom pb-2 text-secondary">Panel de Gestión Logística</h2>
        </div>
        
        @if (TempData.Peek("UsuarioRol")?.ToString() == "Administrador")
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-primary">
                    <div class="card-body text-center">
                        <div class="display-4 text-primary mb-3">
                            <i class="bi bi-people"></i>
                        </div>
                        <h5 class="card-title">Gestión de Usuarios</h5>
                        <p class="card-text text-muted">Consulta, edita y desactiva el personal de la plataforma.</p>
                        <a asp-page="/Usuarios" class="btn btn-primary w-100">Administrar</a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-info">
                <div class="card-body text-center">
                    <div class="display-4 text-info mb-3">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <h5 class="card-title">Pedidos y Cargas</h5>
                    <p class="card-text text-muted">Visualiza las solicitudes de transporte de los clientes.</p>
                    <a href="#" class="btn btn-info text-white w-100">Ver Pedidos</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body text-center">
                    <div class="display-4 text-warning mb-3">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h5 class="card-title">Flota de Vehículos</h5>
                    <p class="card-text text-muted">Control de estado y disponibilidad de camiones.</p>
                    <a href="#" class="btn btn-warning text-white w-100">Ver Flota</a>
                </div>
            </div>
        </div>
    </div>
</div>