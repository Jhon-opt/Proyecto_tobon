@page
@model TransportesTobonApp.Pages.LoginModel
@{
    ViewData["Title"] = "Acceso - Transportes Tobón";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0 fw-bold">Transportes Tobón</h3>
                    <small class="text-uppercase tracking-wider">Gestión Logística Integral</small>
                </div>
                <div class="card-body p-5">
                    <form method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Correo Corporativo</label>
                            <div class="input-group border rounded shadow-sm">
                                <span class="input-group-text bg-white border-0"><i class="bi bi-envelope text-primary"></i></span>
                                <input type="email" asp-for="Email" class="form-control border-0" placeholder="ejemplo@transportestobon.com" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Contraseña</label>
                            <div class="input-group border rounded shadow-sm">
                                <span class="input-group-text bg-white border-0"><i class="bi bi-lock text-primary"></i></span>
                                <input type="password" asp-for="Password" class="form-control border-0" placeholder="••••••••" required />
                            </div>
                        </div>

                        <div class="mb-4 d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="recordar">
                                <label class="form-check-label small text-muted" for="recordar">Recordar sesión</label>
                            </div>
                            <a href="#" class="small text-primary text-decoration-none">¿Olvidó su clave?</a>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Message))
                        {
                            <div class="alert alert-danger py-2 text-center border-0 shadow-sm mb-4">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.Message
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm border-0">
                            <span class="h6 mb-0 text-uppercase fw-bold">Ingresar al Sistema</span>
                        </button>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3 border-0">
                    <span class="text-muted small">&copy; 2026 - Universidad Distrital Francisco José de Caldas</span>
                </div>
            </div>
        </div>
    </div>
</div>