@page
@model TransportesTobonApp.Pages.UsuariosModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill me-2"></i>Personal Registrado</h2>
        <a asp-page="/Registro" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i>Nuevo Usuario</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ListaUsuarios)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><strong>@item.Nombre</strong></td>
                            <td>@item.Email</td>
                            <td><span class="badge bg-info text-dark">@item.Rol</span></td>
                            <td>
                                @if (item.Estado) {
                                    <span class="badge bg-success">Activo</span>
                                } else {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td>
    <div class="d-flex gap-2">
        <a asp-page="/EditarUsuario" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar">
            <i class="bi bi-pencil"></i>
        </a>

        <form method="post" asp-page-handler="ToggleEstado">
            <input type="hidden" name="id" value="@item.Id" />
            <input type="hidden" name="estadoActual" value="@item.Estado.ToString().ToLower()" />
            <button type="submit" class="btn btn-sm @(item.Estado ? "btn-outline-warning" : "btn-outline-success")" 
                    title="@(item.Estado ? "Desactivar" : "Activar")">
                <i class="bi @(item.Estado ? "bi-person-x" : "bi-person-check")"></i>
            </button>
        </form>

        <form method="post" asp-page-handler="Eliminar" onsubmit="return confirm('¿Seguro que quieres borrar este usuario permanentemente?');">
            <input type="hidden" name="id" value="@item.Id" />
            <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar de la Base de Datos">
                <i class="bi bi-trash"></i>
            </button>
        </form>
    </div>
</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>